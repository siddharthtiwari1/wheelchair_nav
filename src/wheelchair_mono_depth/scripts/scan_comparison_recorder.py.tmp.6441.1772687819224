#!/usr/bin/env python3
"""
Scan Comparison Recorder — Stereo vs Mono fused LaserScan comparison.
=====================================================================
Created: 2026-03-05

Subscribes to /scan_fused (stereo) and /scan_mono_fused (mono), captures
N time-synced scan pairs, computes per-pair metrics per distance band,
saves CSV, and republishes both scans on RELIABLE QoS for RViz overlay.

Also captures per-camera debug scans for detailed analysis:
  /scan_front_camera, /scan_left_camera, /scan_right_camera  (stereo)
  /scan_mono_front_camera, /scan_mono_left_camera, /scan_mono_right_camera  (mono)

Usage:
    ros2 run wheelchair_mono_depth scan_comparison_recorder --ros-args \
        -p num_captures:=6 \
        -p capture_interval_sec:=5.0 \
        -p output_dir:=/home/sidd/wheelchair_nav/eval_output/scan_comparison

Output:
    scan_comparison.csv — per-capture, per-band metrics
    summary.txt — aggregated results table
"""

import array as _array
import csv
import os
import time
from collections import deque
from datetime import datetime

import numpy as np

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, ReliabilityPolicy, DurabilityPolicy, HistoryPolicy

from sensor_msgs.msg import LaserScan


SENSOR_QOS = QoSProfile(
    reliability=ReliabilityPolicy.BEST_EFFORT,
    durability=DurabilityPolicy.VOLATILE,
    history=HistoryPolicy.KEEP_LAST,
    depth=5,
)

RELIABLE_QOS = QoSProfile(
    reliability=ReliabilityPolicy.RELIABLE,
    durability=DurabilityPolicy.VOLATILE,
    history=HistoryPolicy.KEEP_LAST,
    depth=5,
)

DISTANCE_BANDS = [
    ('0-1m', 0.0, 1.0),
    ('1-2m', 1.0, 2.0),
    ('2-3m', 2.0, 3.0),
    ('3-5m', 3.0, 5.0),
]


class ScanComparisonRecorder(Node):
    def __init__(self):
        super().__init__('scan_comparison_recorder')

        self.declare_parameter('stereo_topic', '/scan_fused')
        self.declare_parameter('mono_topic', '/scan_mono_fused')
        self.declare_parameter('num_captures', 6)
        self.declare_parameter('capture_interval_sec', 5.0)
        self.declare_parameter('auto_start_delay_sec', 10.0)
        self.declare_parameter('sync_slop_sec', 0.15)
        self.declare_parameter('output_dir',
                               '/home/sidd/wheelchair_nav/eval_output/scan_comparison')
        self.declare_parameter('fp_threshold_m', 0.5)

        self.num_captures = self.get_parameter('num_captures').value
        self.capture_interval = self.get_parameter('capture_interval_sec').value
        self.auto_start_delay = self.get_parameter('auto_start_delay_sec').value
        self.sync_slop = self.get_parameter('sync_slop_sec').value
        self.output_dir = self.get_parameter('output_dir').value
        self.fp_threshold = self.get_parameter('fp_threshold_m').value

        os.makedirs(self.output_dir, exist_ok=True)

        # State
        self._stereo_buf = deque(maxlen=20)
        self._mono_buf = deque(maxlen=20)
        self._captures = []
        self._capture_count = 0
        self._start_time = time.monotonic()
        self._last_capture_time = 0.0
        self._done = False

        # Subscribe with BEST_EFFORT (match publishers)
        stereo_topic = self.get_parameter('stereo_topic').value
        mono_topic = self.get_parameter('mono_topic').value

        self.create_subscription(
            LaserScan, stereo_topic, self._stereo_cb, SENSOR_QOS)
        self.create_subscription(
            LaserScan, mono_topic, self._mono_cb, SENSOR_QOS)

        # Republish on RELIABLE QoS for RViz
        self._stereo_relay = self.create_publisher(
            LaserScan, '/comparison/scan_stereo', RELIABLE_QOS)
        self._mono_relay = self.create_publisher(
            LaserScan, '/comparison/scan_mono', RELIABLE_QOS)
        self._diff_pub = self.create_publisher(
            LaserScan, '/comparison/scan_diff', RELIABLE_QOS)

        # Timer for matching + capturing
        self.create_timer(0.1, self._match_cb)

        self.get_logger().info(
            f'Scan Comparison Recorder: {self.num_captures} captures '
            f'@ {self.capture_interval}s interval')
        self.get_logger().info(
            f'  Stereo: {stereo_topic} | Mono: {mono_topic}')
        self.get_logger().info(
            f'  Auto-start after {self.auto_start_delay}s')
        self.get_logger().info(
            f'  Output: {self.output_dir}')

    def _stereo_cb(self, msg: LaserScan):
        stamp = msg.header.stamp.sec + msg.header.stamp.nanosec * 1e-9
        self._stereo_buf.append((stamp, msg))
        # Relay for RViz
        self._stereo_relay.publish(msg)

    def _mono_cb(self, msg: LaserScan):
        stamp = msg.header.stamp.sec + msg.header.stamp.nanosec * 1e-9
        self._mono_buf.append((stamp, msg))
        # Relay for RViz
        self._mono_relay.publish(msg)

    def _match_cb(self):
        if self._done:
            return

        now = time.monotonic()
        elapsed = now - self._start_time

        # Wait for warmup
        if elapsed < self.auto_start_delay:
            return

        # Rate limit captures
        if (now - self._last_capture_time) < self.capture_interval:
            return

        if not self._stereo_buf or not self._mono_buf:
            return

        # Find best matching pair by timestamp
        latest_stereo_stamp, latest_stereo_msg = self._stereo_buf[-1]
        best_mono = None
        best_dt = float('inf')

        for mono_stamp, mono_msg in self._mono_buf:
            dt = abs(latest_stereo_stamp - mono_stamp)
            if dt < best_dt:
                best_dt = dt
                best_mono = (mono_stamp, mono_msg)

        if best_mono is None or best_dt > self.sync_slop:
            return

        _, mono_msg = best_mono

        # Compute metrics
        metrics = self._compute_metrics(latest_stereo_msg, mono_msg)
        if metrics is None:
            return

        self._capture_count += 1
        metrics['capture_id'] = self._capture_count
        metrics['timestamp'] = datetime.now().isoformat()
        metrics['sync_dt_ms'] = best_dt * 1000.0
        self._captures.append(metrics)
        self._last_capture_time = now

        # Publish diff scan for RViz
        self._publish_diff(latest_stereo_msg, mono_msg)

        # Log
        self.get_logger().info(
            f'Capture {self._capture_count}/{self.num_captures} | '
            f'MAE={metrics["mae"]:.4f}m  '
            f'AbsRel={metrics["abs_rel"]:.4f}  '
            f'FP={metrics["fp_rate"]:.3f}  '
            f'FN={metrics["fn_rate"]:.3f}  '
            f'sync={best_dt*1000:.0f}ms')

        if self._capture_count >= self.num_captures:
            self._save_results()
            self._done = True

    def _compute_metrics(self, stereo_msg: LaserScan, mono_msg: LaserScan):
        """Compute per-scan comparison metrics."""
        s = np.array(stereo_msg.ranges, dtype=np.float32)
        m = np.array(mono_msg.ranges, dtype=np.float32)

        if len(s) != len(m):
            self.get_logger().warn(
                f'Scan length mismatch: stereo={len(s)}, mono={len(m)}')
            return None

        # Valid: finite and positive
        s_valid = np.isfinite(s) & (s > 0.01)
        m_valid = np.isfinite(m) & (m > 0.01)
        both_valid = s_valid & m_valid

        n_overlap = int(np.sum(both_valid))
        if n_overlap < 10:
            return None

        s_v = s[both_valid]
        m_v = m[both_valid]
        abs_err = np.abs(s_v - m_v)

        # Overall metrics
        result = {
            'n_stereo_valid': int(np.sum(s_valid)),
            'n_mono_valid': int(np.sum(m_valid)),
            'n_overlap': n_overlap,
            'mae': float(np.mean(abs_err)),
            'rmse': float(np.sqrt(np.mean(abs_err ** 2))),
            'abs_rel': float(np.mean(abs_err / np.clip(s_v, 0.01, None))),
            'max_error': float(np.max(abs_err)),
            'median_error': float(np.median(abs_err)),
        }

        # Correlation
        if n_overlap > 2:
            result['pearson_corr'] = float(np.corrcoef(s_v, m_v)[0, 1])

        # FP: mono sees something but stereo doesn't (potential ghost obstacles)
        fp_mask = m_valid & ~s_valid
        result['fp_count'] = int(np.sum(fp_mask))
        result['fp_rate'] = float(np.sum(fp_mask)) / max(np.sum(m_valid), 1)

        # FN: stereo sees something but mono doesn't (missed obstacles)
        fn_mask = s_valid & ~m_valid
        result['fn_count'] = int(np.sum(fn_mask))
        result['fn_rate'] = float(np.sum(fn_mask)) / max(np.sum(s_valid), 1)

        # Directional: is mono systematically closer or farther?
        result['mean_bias'] = float(np.mean(m_v - s_v))  # +ve = mono farther

        # Per-band metrics
        for band_name, lo, hi in DISTANCE_BANDS:
            band_mask = both_valid & (s >= lo) & (s < hi)
            n_band = int(np.sum(band_mask))
            if n_band < 5:
                result[f'{band_name}_n'] = n_band
                continue

            s_b = s[band_mask]
            m_b = m[band_mask]
            err_b = np.abs(s_b - m_b)

            result[f'{band_name}_n'] = n_band
            result[f'{band_name}_mae'] = float(np.mean(err_b))
            result[f'{band_name}_rmse'] = float(np.sqrt(np.mean(err_b ** 2)))
            result[f'{band_name}_abs_rel'] = float(
                np.mean(err_b / np.clip(s_b, 0.01, None)))

            # Band FN rate
            band_s_valid = s_valid & (s >= lo) & (s < hi)
            band_fn = band_s_valid & ~m_valid
            result[f'{band_name}_fn_rate'] = float(
                np.sum(band_fn)) / max(np.sum(band_s_valid), 1)

        return result

    def _publish_diff(self, stereo_msg: LaserScan, mono_msg: LaserScan):
        """Publish |stereo - mono| as a scan for RViz visualization."""
        s = np.array(stereo_msg.ranges, dtype=np.float32)
        m = np.array(mono_msg.ranges, dtype=np.float32)

        s_valid = np.isfinite(s) & (s > 0.01)
        m_valid = np.isfinite(m) & (m > 0.01)
        both = s_valid & m_valid

        diff = np.full_like(s, np.inf)
        diff[both] = np.abs(s[both] - m[both])

        msg = LaserScan()
        msg.header = stereo_msg.header
        msg.angle_min = stereo_msg.angle_min
        msg.angle_max = stereo_msg.angle_max
        msg.angle_increment = stereo_msg.angle_increment
        msg.time_increment = stereo_msg.time_increment
        msg.scan_time = stereo_msg.scan_time
        msg.range_min = 0.0
        msg.range_max = 5.0
        msg.ranges = _array.array('f', diff.astype(np.float32).tobytes())
        self._diff_pub.publish(msg)

    def _save_results(self):
        """Save comparison metrics to CSV and summary."""
        if not self._captures:
            self.get_logger().warn('No captures to save')
            return

        # CSV
        all_keys = set()
        for c in self._captures:
            all_keys.update(c.keys())
        fields = sorted(all_keys)

        csv_path = os.path.join(self.output_dir, 'scan_comparison.csv')
        with open(csv_path, 'w', newline='') as f:
            writer = csv.DictWriter(f, fieldnames=fields)
            writer.writeheader()
            writer.writerows(self._captures)

        self.get_logger().info(f'CSV saved: {csv_path}')

        # Summary
        lines = []
        lines.append('=' * 70)
        lines.append('SCAN COMPARISON: Stereo (scan_fusion_v9) vs Mono (DA3Metric-Large)')
        lines.append(f'Captures: {len(self._captures)}')
        lines.append(f'Date: {datetime.now().isoformat()}')
        lines.append('=' * 70)

        maes = [c['mae'] for c in self._captures]
        rmses = [c['rmse'] for c in self._captures]
        absrels = [c['abs_rel'] for c in self._captures]
        fps = [c['fp_rate'] for c in self._captures]
        fns = [c['fn_rate'] for c in self._captures]
        biases = [c['mean_bias'] for c in self._captures]

        lines.append(f'\n{"Metric":<15} {"Mean":>10} {"Std":>10} {"Min":>10} {"Max":>10}')
        lines.append('-' * 55)
        for name, vals in [
            ('MAE (m)', maes), ('RMSE (m)', rmses), ('AbsRel', absrels),
            ('FP rate', fps), ('FN rate', fns), ('Bias (m)', biases),
        ]:
            lines.append(
                f'{name:<15} {np.mean(vals):>10.4f} {np.std(vals):>10.4f} '
                f'{np.min(vals):>10.4f} {np.max(vals):>10.4f}')

        # Per-band summary
        lines.append(f'\nPer-Band MAE (mean across {len(self._captures)} captures):')
        lines.append(f'  {"Band":<8} {"MAE":>8} {"RMSE":>8} {"AbsRel":>8} {"FN rate":>8}')
        lines.append('  ' + '-' * 40)
        for band_name, _, _ in DISTANCE_BANDS:
            key_mae = f'{band_name}_mae'
            key_rmse = f'{band_name}_rmse'
            key_ar = f'{band_name}_abs_rel'
            key_fn = f'{band_name}_fn_rate'

            vals_mae = [c[key_mae] for c in self._captures if key_mae in c]
            vals_rmse = [c[key_rmse] for c in self._captures if key_rmse in c]
            vals_ar = [c[key_ar] for c in self._captures if key_ar in c]
            vals_fn = [c[key_fn] for c in self._captures if key_fn in c]

            if vals_mae:
                lines.append(
                    f'  {band_name:<8} {np.mean(vals_mae):>8.4f} '
                    f'{np.mean(vals_rmse):>8.4f} '
                    f'{np.mean(vals_ar):>8.4f} '
                    f'{np.mean(vals_fn):>8.4f}')

        text = '\n'.join(lines)
        summary_path = os.path.join(self.output_dir, 'summary.txt')
        with open(summary_path, 'w') as f:
            f.write(text)

        self.get_logger().info(f'\n{text}')
        self.get_logger().info(f'\nSummary saved: {summary_path}')
        self.get_logger().info('Recording complete. Node will keep relaying for RViz.')


def main(args=None):
    rclpy.init(args=args)
    node = ScanComparisonRecorder()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
